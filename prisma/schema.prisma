generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. 大脑配置：存储 API Key 和模型选型
model Brain {
  id        String   @id @default(uuid())
  name      String
  provider  String
  modelName String
  apiKey    String
  baseUrl   String?
  type      String   @default("chat")  // "chat" | "image"
  createdAt DateTime @default(now())
  roles     Role[]
}

// 2. 有灵魂的个体：直接参与对话的实体
model Role {
  id        String    @id @default(uuid())
  name      String
  soul      String
  rule      String
  summary   String?   // LLM 压缩后的历史对话摘要，始终拼入 system prompt
  avatar    String?
  brain     Brain     @relation(fields: [brainId], references: [id])
  brainId   String
  messages  Message[]
  createdAt DateTime  @default(now())

  @@index([brainId])
}

// 3. 原始对话记录（短期记忆来源）
model Message {
  id        String   @id @default(uuid())
  content   String
  sender    String   // user / assistant / system
  type      String   @default("text")  // "text" | "image"
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  createdAt DateTime @default(now())

  @@index([roleId])
}

