generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. 大脑配置：存储 API Key 和模型选型
model Brain {
  id        String   @id @default(uuid())
  name      String
  provider  String
  modelName String
  apiKey    String
  baseUrl   String?
  type      String   @default("chat")  // "chat" | "image"
  createdAt DateTime @default(now())
  roles     Role[]
}

// 2. 有灵魂的个体：直接参与对话的实体
model Role {
  id        String    @id @default(uuid())
  name      String
  soul      String
  rule      String
  summary   String?   // LLM 压缩后的历史对话摘要，始终拼入 system prompt
  avatar    String?
  brain     Brain     @relation(fields: [brainId], references: [id])
  brainId   String
  messages  Message[]
  createdAt DateTime  @default(now())

  @@index([brainId])
}

// 3. 原始对话记录（短期记忆来源）
model Message {
  id        String   @id @default(uuid())
  content   String
  sender    String   // user / assistant / system
  type      String   @default("text")  // "text" | "image"
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  createdAt DateTime @default(now())

  @@index([roleId])
}

// 4. Agent 会话：一次独立的 agent 任务
model AgentSession {
  id        String   @id @default(uuid())
  roleId    String
  title     String   // 自动摘要或用户命名
  status    String   @default("active")  // "active" | "archived"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AgentMessage[]

  @@index([roleId])
}

// 5. Agent 消息：包含 tool_use/tool_result 的多角色消息
model AgentMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // "user" | "assistant" | "tool_use" | "tool_result"
  content   String
  type      String   @default("text")  // "text" | "tool_call" | "tool_result"
  toolName  String?  // tool_use 的工具名
  toolId    String?  // tool_use_id，匹配 tool_use/tool_result
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([sessionId])
}

